        };
    }

    // ── Members ───────────────────────────────
    torch::Device              device_{ torch::kCPU };
    torch::jit::script::Module model_;
    std::string                model_name_;
    std::vector<std::string>   food_classes_;
    ProcessorConfig            processor_;                 // mirrors self.processor in Python
    float                      confidence_threshold_{ 0.5f };
};

// ─────────────────────────────────────────────
// Helper: pretty-print results
// ─────────────────────────────────────────────

void print_result(const AnalysisResult& result)
{
    if (!result.error.empty()) {
        std::cerr << "Error: " << result.error << "\n";
        return;
    }

    std::cout << "Model : " << result.model << "\n";
    std::cout << "Input : " << result.input_shape[1] << "x"
                            << result.input_shape[0] << " (WxH)\n";

    if (result.top_prediction.has_value()) {
        const auto& top = *result.top_prediction;
        std::cout << "Top   : " << top.food_class
                  << "  (" << (top.confidence * 100.f) << "%)\n";
    } else {
        std::cout << "Top   : none above threshold\n";
    }

    std::cout << "Predictions:\n";
    for (size_t i = 0; i < result.predictions.size(); ++i) {
        const auto& p = result.predictions[i];
        std::cout << "  " << (i + 1) << ". "
                  << p.food_class << " — "
                  << (p.confidence * 100.f) << "%\n";
    }
}

// ─────────────────────────────────────────────
// main() — minimal usage example
// ─────────────────────────────────────────────

int main(int argc, char* argv[])
{
    if (argc < 3) {
        std::cerr << "Usage: vit_analyzer <model.pt> <image.jpg> [top_k]\n";
        return 1;
    }

    const std::string model_path = argv[1];
    const std::string image_path = argv[2];
    const int         top_k      = (argc >= 4) ? std::stoi(argv[3]) : 5;

    // Load image
    cv::Mat image = cv::imread(image_path);
    if (image.empty()) {
        std::cerr << "Failed to load image: " << image_path << "\n";
        return 1;
    }

    try {
        ViTAnalyzer analyzer(model_path, /*threshold=*/0.5f);

        AnalysisResult result = analyzer.analyze(image, top_k);
        print_result(result);

        // Category
        std::string category = analyzer.get_food_category(result.top_prediction);
        std::cout << "Category: " << category << "\n";

        // Fine-tune info
        FineTuneInfo info = analyzer.fine_tune_info();
        std::cout << "\nFine-tune tips:\n";
        for (const auto& tip : info.training_tips)
            std::cout << "  - " << tip << "\n";

    } catch (const std::exception& e) {
        std::cerr << "Fatal: " << e.what() << "\n";
        return 1;
    }

    return 0;
}
